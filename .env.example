# ============================================================
# BACCARAT PRO — Variables d'environnement
# Copiez ce fichier en .env et remplissez vos valeurs
# ============================================================

# --- OBLIGATOIRES (a remplir absolument) ---
API_ID=
API_HASH=
BOT_TOKEN=
ADMIN_ID=

# --- OPTIONNEL : session Telegram pre-generee ---
TELEGRAM_SESSION=

# --- CANAUX DE PREDICTION (deja pre-configures par defaut) ---
# Modifiez uniquement si vous utilisez vos propres canaux
# PREDICTION_CHANNEL_ID=-1003774449498
# CHANNEL_INVERSE_ID=-1003800711004
# CHANNEL_MANQUE_ID=-1003773458877
# CHANNEL_COMPTEUR3_ID=-1003572542646
# CHANNEL_COMPTEUR1_ID=-1003572542646

# --- PARAMETRES (valeurs par defaut recommandees) ---
# PORT=10000         # Injecte automatiquement par la plateforme
# API_POLL_INTERVAL=5
# COMPTEUR2_ACTIVE=true
# COMPTEUR2_B=5
# COMPTEUR3_ACTIVE=true
# COMPTEUR3_B=5
# COMPTEUR1_ACTIVE=true
# COMPTEUR1_B=8
